/* 1. O Fundo Escuro (Overlay) */
.modal-overlay {
    display: none; /* Escondido por padrão, o JS muda para 'flex' */
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.85); /* Fundo preto semi-transparente */
    z-index: 9999; /* Garante que fique acima de tudo */
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(5px); /* Efeito de desfoque no fundo */
}

.modal-grid {
    display: grid;
    grid-template-columns: 350px 1fr; /* Capa à esquerda, info à direita */
    gap: 30px;
}

/* Estilo para a Tracklist */
.modal-tracklist {
    list-style: none;
    padding: 0;
    margin-top: 10px;
    border-top: 1px solid var(--cor-borda);
}

.modal-tracklist li {
    padding: 8px 0;
    border-bottom: 1px solid var(--cor-borda);
    display: flex;
    justify-content: space-between;
}

.track-num { color: var(--cor-destaque); font-weight: bold; margin-right: 10px; }

@media (max-width: 768px) {
    .modal-grid { grid-template-columns: 1fr; }
    .modal-col-capa { max-width: 250px; margin: 0 auto; }
}

