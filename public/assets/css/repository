@media (max-width: 900px) {
    .metric-grid {
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    }
}

@media (max-width: 600px) {
    .metric-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .span-card {
        flex-direction: column;
        align-items: flex-start;
    }

    .span-value-area {
        text-align: left;
        margin-top: 15px;
    }
}

/* 1. O Fundo Escuro (Overlay) */
.modal-overlay {
    display: none; /* Escondido por padrão, o JS muda para 'flex' */
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.85); /* Fundo preto semi-transparente */
    z-index: 9999; /* Garante que fique acima de tudo */
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(5px); /* Efeito de desfoque no fundo */
}

/* 2. A Caixa do Modal */
.modal-content {
    background-color: var(--cor-card, #1e1e1e);
    width: 90%;
    max-width: 900px;
    max-height: 90vh;
    border-radius: 12px;
    position: relative;
    padding: 30px;
    overflow-y: auto; /* Scroll interno se o conteúdo for longo */
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    border: 1px solid var(--cor-borda, #333);
}

/* 3. O Botão de Fechar (X) */
.modal-close {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 2rem;
    color: #888;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
}

.modal-close:hover {
    color: #fff;
}

/* 4. Organização Interna (Grid do Modal) */
.modal-grid {
    display: grid;
    grid-template-columns: 350px 1fr; /* Capa à esquerda, info à direita */
    gap: 30px;
}

.modal-capa {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}

/* Estilo para a Tracklist */
.modal-tracklist {
    list-style: none;
    padding: 0;
    margin-top: 10px;
    border-top: 1px solid var(--cor-borda);
}

.modal-tracklist li {
    padding: 8px 0;
    border-bottom: 1px solid var(--cor-borda);
    display: flex;
    justify-content: space-between;
}

.track-num { color: var(--cor-destaque); font-weight: bold; margin-right: 10px; }

/* Responsividade do Modal */
@media (max-width: 768px) {
    .modal-grid { grid-template-columns: 1fr; }
    .modal-col-capa { max-width: 250px; margin: 0 auto; }
}
